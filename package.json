{
  "name": "user-automation-platform",
  "version": "1.6.4",
  "private": true,
  "workspaces": [
    "apps/*",
    "integrations/*",
    "packages/*"
  ],
  "description": "User-based automation platform (Node.js + Express + Prisma). Each user owns integrations with their own integration.js + handler.js, executed via a shared runner with webhook, scheduled, and manual triggers.",
  "main": "src/server.js",
  "scripts": {
    "postinstall": "node scripts/prisma-postinstall.js",
    "dev:api": "npm --workspace @automation/api run dev",
    "dev:worker:gmail-priority": "npm --workspace @automation/gmail-priority run dev",
    "dev:worker:shopify-priority": "npm --workspace @automation/shopify-priority run dev",
    "dev": "node src/server.js",
    "dev:tunnel": "node scripts/ngrok-tunnel.js",
    "start": "node scripts/prisma-postinstall.js && node src/server.js",
    "build:dashboard": "npm --prefix frontend/dashboard run build",
    "db:generate": "prisma generate",
    "db:generate:aws": "prisma generate --schema=prisma/schema.postgres.prisma",
    "db:migrate": "prisma migrate dev --name init",
    "db:deploy": "prisma migrate deploy",
    "db:push:aws": "prisma db push --schema=prisma/schema.postgres.prisma --accept-data-loss",
    "db:seed": "node prisma/seed.js",
    "sync:integration-db": "node scripts/sync-integration-db.js",
    "db:reset": "prisma migrate reset --force",
    "validate:integrations": "node scripts/validate-integrations.js",
    "skill:restart-app": "node scripts/restart-skill.js",
    "skill:new-integration": "node scripts/integration-gate-skill.js",
    "test": "npm run validate:integrations && cross-env NODE_ENV=test jest --runInBand && npm run test:integration:gmail-priority && npm run test:integration:priority-order-itc && npm --workspace @automation/shopify-priority test && npm --workspace @automation/salesforce-priority test",
    "test:api": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watch --runInBand",
    "test:integration:gmail-priority": "npm --workspace @automation/gmail-priority test",
    "test:integration:priority-sales-projects-insights": "npm --workspace @automation/priority-sales-projects-insights test",
    "test:integration:priority-order-itc": "npm --workspace @automation/priority-order-itc test",
    "dev:worker:priority-sales-projects-insights": "npm --workspace @automation/priority-sales-projects-insights run dev",
    "invoke:priority-sales-projects-insights": "npm --workspace @automation/priority-sales-projects-insights run invoke --",
    "dev:worker:priority-order-itc": "npm --workspace @automation/priority-order-itc run dev",
    "invoke:priority-order-itc": "npm --workspace @automation/priority-order-itc run invoke --"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/client-sesv2": "^3.1075.0",
    "@aws-sdk/client-sqs": "^3.1075.0",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "priority-web-sdk": "^3.0.37",
    "prisma": "^5.20.0"
  },
  "devDependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
