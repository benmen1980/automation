// Postgres counterpart of schema.prisma, used for AWS deployments (RDS).
//
// Kept as a separate file rather than swapping the provider in schema.prisma
// in place, so local dev keeps working against SQLite while this one targets
// the RDS instance. The models are identical and provider-agnostic (no
// SQLite-only or Postgres-only features used) — see docs/ops/aws-deployment-plan.md / docs/ops/aws-testing-environment-runbook.md
// for how this gets selected (PRISMA_SCHEMA env var + the `:aws` npm scripts).
//
// Keep this file's models in sync with schema.prisma whenever the data model
// changes — there is currently no automated check for that.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
  viewer
}

enum UserStatus {
  active
  disabled
}

enum IntegrationType {
  webhook
  scheduled
}

enum IntegrationStatus {
  active
  inactive
}

enum TriggerType {
  webhook
  scheduled
  manual
}

enum ExecutionMode {
  live
  test
  dry_run
  mock_input
  mock_output
  replay
}

enum ExecutionStatus {
  pending
  queued
  running
  retrying
  success
  failed
  dead_letter
}

enum LogLevel {
  debug
  info
  warning
  error
}

model User {
  id           String   @id @default(cuid())
  // Stable, human-readable slug (e.g. "user_001"). Used as :userSlug in the
  // webhook URL and as the folder name under src/integrations/. Decoupled
  // from the internal cuid `id` on purpose, per the folder convention in
  // docs/product/product-architecture-spec.md section 7 (e.g. src/integrations/user_001/whatsapp-order).
  slug         String   @unique
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(user)
  status       UserStatus @default(active)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  integrations Integration[]
  executions   Execution[]
  logs         Log[]
}

model Integration {
  id               String            @id @default(cuid())
  userId           String
  name             String
  version          String            @default("1.0.0")
  description      String?
  slug             String
  type             IntegrationType
  status           IntegrationStatus @default(active)
  codeFolder       String
  definitionFile   String            @default("integration.js")
  handlerFile      String            @default("handler.js")
  manualRunEnabled Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user             User               @relation(fields: [userId], references: [id])
  credentials      Credential[]
  executions       Execution[]
  logs             Log[]
  webhookSettings  WebhookSettings?
  scheduleSettings ScheduleSettings?

  @@unique([userId, slug])
}

model Credential {
  id             String   @id @default(cuid())
  userId         String
  integrationId  String
  key            String
  // For non-secret values: the literal value is stored here (JSON-encoded).
  // For secret values: this stores a reference name; the actual encrypted
  // value lives in the secrets store (local-data/secrets.local.json in dev,
  // AWS Secrets Manager in production) and is never returned to the client.
  valueReference String
  type           String
  isSecret       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  integration    Integration @relation(fields: [integrationId], references: [id])

  @@unique([integrationId, key])
}

model WebhookSettings {
  id                    String   @id @default(cuid())
  integrationId         String   @unique
  webhookUrl            String
  secretTokenReference  String?
  allowedMethod         String   @default("POST")
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  integration           Integration @relation(fields: [integrationId], references: [id])
}

model ScheduleSettings {
  id             String    @id @default(cuid())
  integrationId  String    @unique
  cronExpression String
  timezone       String    @default("UTC")
  active         Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  integration    Integration @relation(fields: [integrationId], references: [id])
}

model Execution {
  id                String          @id @default(cuid())
  userId            String
  integrationId     String
  triggerType       TriggerType
  executionMode     ExecutionMode
  status            ExecutionStatus @default(pending)
  startedAt         DateTime?
  finishedAt        DateTime?
  inputPayload      String?
  outputPayload     String?
  errorMessage      String?
  sourceExecutionId String?
  retryCount        Int             @default(0)
  maxAttempts       Int             @default(3)
  queueMessageId    String?
  queueUrl          String?
  cloudWatchLogRef  String?
  externalRequestId String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User        @relation(fields: [userId], references: [id])
  integration       Integration @relation(fields: [integrationId], references: [id])
  logs              Log[]
}

model Log {
  id            String        @id @default(cuid())
  userId        String
  integrationId String
  executionId   String?
  level         LogLevel      @default(info)
  message       String
  metadata      String?
  executionMode ExecutionMode?
  isTest        Boolean       @default(false)
  createdAt     DateTime      @default(now())

  user          User         @relation(fields: [userId], references: [id])
  integration   Integration  @relation(fields: [integrationId], references: [id])
  execution     Execution?   @relation(fields: [executionId], references: [id])
}
