NODE_ENV=development
PORT=3000

# Prisma datasource. For local dev we use SQLite (file-based, zero setup).
# For AWS production, switch provider in prisma/schema.prisma to "postgresql"
# and point this at your RDS instance, e.g.:
# DATABASE_URL=postgresql://user:password@your-rds-endpoint:5432/automation_app
DATABASE_URL="file:../local-data/dev.db"

JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=12h

AWS_REGION=us-west-2
AWS_PROFILE=automation-dev

AUTH_MODE=mock
QUEUE_MODE=local
# SQS mode publishes execution jobs and returns queued immediately.
# Prefer per-integration queue URLs; fallback SQS_QUEUE_URL is useful for one-queue test environments.
SQS_QUEUE_URL=
SQS_QUEUE_URL_CMRTOMUDR0001105JK8E1SPO6=
# API base reachable from Lambda; SQS receives only the per-execution callback URL.
INTEGRATION_WORKER_STATUS_CALLBACK_BASE_URL=
# Inject the same callback secret into the API and worker from deployment secret storage.
INTEGRATION_WORKER_CALLBACK_TOKEN=
AUTOMATION_WORKER_CALLBACK_TOKEN=
AUTOMATION_WORKER_CALLBACK_TOKEN_SECRET_ID=
AUTOMATION_FINALIZATION_TABLE_NAME=priority-order-itc-finalization
AUTOMATION_MAX_RECEIVE_COUNT=3
AUTOMATION_CREDENTIAL_ITC_TEMPLATE_MESSAGE_URL=https://sv1.effective-oc.com/api/v2/msg/sendMsg/tempMsg/6a4b93a55c44e81728f3dc89
AUTOMATION_CREDENTIAL_ITC_BEARER_TOKEN=
AUTOMATION_CREDENTIAL_ITC_CHANNEL_ID=whatsapp:+97246960480
AUTOMATION_CREDENTIAL_PRIORITY_WEB_SDK_URL=
AUTOMATION_CREDENTIAL_PRIORITY_WEB_SDK_TABULAINI=tabula.ini
AUTOMATION_CREDENTIAL_PRIORITY_WEB_SDK_LANGUAGE=3
AUTOMATION_CREDENTIAL_PRIORITY_WEB_SDK_COMPANY=
AUTOMATION_CREDENTIAL_PRIORITY_WEB_SDK_APPNAME=
AUTOMATION_CREDENTIAL_PRIORITY_WEB_SDK_USERNAME=
AUTOMATION_CREDENTIAL_PRIORITY_WEB_SDK_PASSWORD=
AUTOMATION_CREDENTIAL_PRIORITY_WEB_SDK_DEVICENAME=
AUTOMATION_CREDENTIAL_PRIORITY_WEB_SDK_ORDER_SORT_OPTION=By Order Number
SQS_QUEUE_URL_GMAIL_PRIORITY=
SQS_QUEUE_URL_SHOPIFY_PRIORITY=
SQS_QUEUE_URL_SALESFORCE_PRIORITY=
SECRETS_MODE=local
SCHEDULER_MODE=local
LOG_MODE=console
CONNECTOR_MODE=mock

# Local ngrok tunnel for testing external webhooks against your dev backend.
# Get an authtoken from the ngrok dashboard and keep it only in your local .env.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=
NGROK_TARGET_PORT=3000
NGROK_PUBLIC_URL_FILE=local-data/ngrok-public-url.txt
PUBLIC_BASE_URL=

LOCAL_SECRET_KEY=dev-only-key-change-me-32-bytes!!

INTEGRATIONS_ROOT=src/integrations

# Gmail API OAuth2 local setup. Use scripts/gmail-get-token.js to generate a refresh token.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
GMAIL_USER_EMAIL=
GMAIL_REFRESH_TOKEN=
GMAIL_USE_LOCAL_FILES=false
GMAIL_LOCAL_CREDENTIALS_DIR=

# Amazon SES email sending. On AWS, prefer SES for outbound app emails.
# The sender identity must be verified in the same AWS region.
EMAIL_PROVIDER=ses
SES_FROM_EMAIL=
SES_REGION=eu-west-1
SES_CONFIGURATION_SET=

# Priority Quote Notification to WhatsApp dashboard credentials.
# These are normally saved per integration in the dashboard; keep local copies
# only for development setup/reference and never commit real values.
PRIORITY_WEB_SDK_URL=
PRIORITY_WEB_SDK_TABULAINI=tabula.ini
PRIORITY_WEB_SDK_LANGUAGE=1
PRIORITY_WEB_SDK_COMPANY=
PRIORITY_WEB_SDK_APPNAME=
PRIORITY_WEB_SDK_USERNAME=shely.l
PRIORITY_WEB_SDK_PASSWORD=
PRIORITY_WEB_SDK_DEVICENAME=
WHATSAPP_BUTTON_URL_PREFIX=https://priority.simplyct.co.il/netfiles/

# Priority OData (TRANSORDER_q / BASEINVOICEREP / BASEINVOICEREPSON) sales/project insights integration.
PRIORITY_ODATA_BASE_URL=https://priority.simplyct.co.il/odata/Priority/tabula.ini/roihd
PRIORITY_BASIC_USERNAME=
PRIORITY_BASIC_PASSWORD=
PRIORITY_ODATA_AUTH_HEADER=
PRIORITY_SALES_PROJECTS_TOP_N=10

# Restart skill memory/settings (optional).
# Configure one or more commands separated by ";".
RESTART_APP_COMMANDS=pm2 restart automation-api;pm2 restart all;npm run dev
RESTART_APP_HISTORY_PATH=local-data/restart-skill/attempts.json
RESTART_APP_HISTORY_LIMIT=50
RESTART_APP_HISTORY_WINDOW_MS=86400000
RESTART_APP_COMMAND_TIMEOUT_MS=20000
