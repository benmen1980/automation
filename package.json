{
  "name": "user-automation-platform",
  "version": "0.1.7",
  "private": true,
  "workspaces": [
    "apps/*",
    "integrations/*",
    "packages/*"
  ],
  "description": "User-based automation platform (Node.js + Express + Prisma). Each user owns integrations with their own integration.js + handler.js, executed via a shared runner with webhook, scheduled, and manual triggers.",
  "main": "src/server.js",
  "scripts": {
    "postinstall": "node scripts/prisma-postinstall.js",
    "dev:api": "npm --workspace @automation/api run dev",
    "dev:worker:gmail-priority": "npm --workspace @automation/gmail-priority run dev",
    "dev:worker:shopify-priority": "npm --workspace @automation/shopify-priority run dev",
    "dev": "node src/server.js",
    "start": "node scripts/prisma-postinstall.js && node src/server.js",
    "build:dashboard": "npm --prefix frontend/dashboard run build",
    "db:generate": "prisma generate",
    "db:generate:aws": "prisma generate --schema=prisma/schema.postgres.prisma",
    "db:migrate": "prisma migrate dev --name init",
    "db:deploy": "prisma migrate deploy",
    "db:push:aws": "prisma db push --schema=prisma/schema.postgres.prisma --accept-data-loss",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force",
    "test": "cross-env NODE_ENV=test jest --runInBand && npm run test:integration:gmail-priority && npm --workspace @automation/shopify-priority test && npm --workspace @automation/salesforce-priority test",
    "test:api": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watch --runInBand",
    "test:integration:gmail-priority": "npm --workspace @automation/gmail-priority test",
    "invoke:gmail-priority": "npm --workspace @automation/gmail-priority run invoke --"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "prisma": "^5.20.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
