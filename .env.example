NODE_ENV=development
PORT=3000

# Prisma datasource. For local dev we use SQLite (file-based, zero setup).
# For AWS production, switch provider in prisma/schema.prisma to "postgresql"
# and point this at your RDS instance, e.g.:
# DATABASE_URL=postgresql://user:password@your-rds-endpoint:5432/automation_app
DATABASE_URL="file:../local-data/dev.db"

JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=12h

AWS_REGION=us-west-2
AWS_PROFILE=automation-dev

AUTH_MODE=mock
QUEUE_MODE=local
SECRETS_MODE=local
SCHEDULER_MODE=local
LOG_MODE=console
CONNECTOR_MODE=mock

LOCAL_SECRET_KEY=dev-only-key-change-me-32-bytes!!

INTEGRATIONS_ROOT=src/integrations
