# Point the EB/ELB health check at the app's real health endpoint
# (GET /health -> {status:'ok', time: ISOString}, defined in src/app.js)
# instead of the default "/" — "/" requires a valid JWT for most routes and
# would otherwise mark healthy instances as failing.
option_settings:
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
